# Copy this file to .env (same folder as docker-compose.yml) and adjust values.

# Host ports
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Packet capture interface inside backend container.
# Leave empty for auto-detect (recommended for most setups).
# Examples:
#   CAPTURE_INTERFACE=eth0
#   CAPTURE_INTERFACE=lo
CAPTURE_INTERFACE=

# Keep false unless your in-container models are known compatible.
AUTO_LOAD_MODELS=false
